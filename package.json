{
  "name": "excalidraw-claude-draw",
  "version": "0.1.0",
  "description": "Generate Excalidraw scenes from natural-language prompts using Claude Code — measured ~10x token savings vs. default invocation.",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./dsl": "./src/dsl/compiler.ts",
    "./parser": "./src/dsl/parser.ts",
    "./server": "./src/server/shim.ts",
    "./catalog": "./src/dsl/catalog.ts"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "src",
    "scripts",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "node --experimental-strip-types --no-warnings test/parser.test.ts && node --experimental-strip-types --no-warnings test/compiler.test.ts && node --experimental-strip-types --no-warnings test/client.test.ts",
    "test:parser": "node --experimental-strip-types --no-warnings test/parser.test.ts",
    "test:compiler": "node --experimental-strip-types --no-warnings test/compiler.test.ts",
    "test:client": "node --experimental-strip-types --no-warnings test/client.test.ts",
    "server": "node --experimental-strip-types --no-warnings src/server/index.ts"
  },
  "engines": {
    "node": ">=22.6"
  },
  "keywords": [
    "excalidraw",
    "claude",
    "claude-code",
    "llm",
    "dsl",
    "mockup",
    "ui-generation",
    "prompt-cache"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/mcmarius11/excalidraw-claude-draw"
  }
}
